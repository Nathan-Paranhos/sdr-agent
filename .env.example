PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Banco local Prisma/SQLite
DATABASE_URL=file:./sdr-agent.db

# Groq API (usado pelo SDR Agent principal)
GROQ_API_KEY=gsk_substitua_esta_chave
# Opcional: varias chaves separadas por virgula. Mantem GROQ_API_KEY funcionando.
# Se as chaves forem da mesma organizacao, o limite de TPM pode continuar compartilhado.
# GROQ_API_KEYS=gsk_chave_1,gsk_chave_2
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.3
GROQ_MIN_DELAY_MS=6500
GROQ_RETRY_ROUNDS=2

# OpenRouter (usado pelo Agente Gerente de Grupo / Agente 2)
OPENROUTER_API_KEY=sk-or-v1-substitua-esta-chave
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_WHISPER_MODEL=openai/whisper-large-v3
OPENROUTER_MAX_TOKENS=1500
OPENROUTER_TEMPERATURE=0.4
OPENROUTER_RETRY_ROUNDS=2
OPENROUTER_REFERER=https://seudominio.com
OPENROUTER_APP_TITLE=SDR Agent Group Manager

# WhatsApp por QR local
WHATSAPP_AUTH_DIR=.wwebjs_auth
WHATSAPP_HEADLESS=true
SEND_FIRST_MESSAGE_IMMEDIATELY=true

# Tenant padrao
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_AGENT_NAME=Lucas
DEFAULT_SERVICE_CATEGORY=automacao comercial e atendimento via WhatsApp

# Numero autorizado a enviar CSV pelo WhatsApp
OPERATOR_PHONE=+5511996961151
OPERATOR_SECRET=senha-painel-operador

# =========================
# Agente Gerente de Grupo (Agente 2 - Tech & Ops)
# =========================
# Liga/desliga a funcao de gerente de grupo. Quando false, nenhuma mensagem de grupo eh processada.
GROUP_MANAGER_ENABLED=false
# ID do grupo WhatsApp que sera monitorado (formato: 120363012345678901@g.us).
# Descubra o ID rodando o bot uma vez e olhando os logs ao receber qualquer mensagem do grupo alvo.
GROUP_MANAGER_TARGET_GROUP_ID=
# Texto de mencao que aciona o gerente (sem prefixo, sem @group)
GROUP_MANAGER_BOT_MENTION=@Genesis
# Comandos que acionam o gerente, separados por virgula
GROUP_MANAGER_COMMANDS=!resumo,!pendencias,!decisoes,!kpis
# Cron no formato padrao node-cron (5 campos: minuto hora dia mes diaSemana)
GROUP_MANAGER_NEWS_CRON=0 9 * * *
GROUP_MANAGER_NEWS_TIMEZONE=America/Sao_Paulo
# Quantas horas de historico enviar para o LLM quando o gerente for acionado
GROUP_MANAGER_HISTORY_HOURS=24
GROUP_MANAGER_HISTORY_LIMIT=100
# Transcreve audios (ptt) via OpenRouter Whisper antes de salvar
GROUP_MANAGER_TRANSCRIBE_AUDIO=true
# NewsAPI (opcional; sem ela, o bot usa apenas HackerNews)
GROUP_MANAGER_NEWSAPI_KEY=
GROUP_MANAGER_NEWSAPI_COUNTRY=us
GROUP_MANAGER_NEWSAPI_CATEGORY=technology
GROUP_MANAGER_HACKERNEWS_LIMIT=30
# Quantas noticias o curador deve selecionar por manha
GROUP_MANAGER_NEWS_TOP_N=3

# Configurações do Agente Hermes (Proatividade e Self-Learning)
HERMES_PROACTIVE_ENABLED=true
HERMES_PROACTIVE_PROBABILITY=0.4
HERMES_COOLDOWN_SEC=120
